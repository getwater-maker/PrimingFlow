{
  "_comment": "PLACEHOLDER — Wan2.2-I2V-A14B (image-to-video) 워크플로. kijai/ComfyUI-WanVideoWrapper 노드 사용. 공식 example: https://github.com/kijai/ComfyUI-WanVideoWrapper/tree/main/example_workflows — Pod 띄운 후 ComfyUI 에서 i2v example 로드하여 Save(API Format) export 한 후 이 파일을 교체하세요.",
  "_slot_node_ids": {
    "motionPrompt": "30",
    "inputImage": "20",
    "seed": "40",
    "frames": "40",
    "output": "50"
  },
  "1": {
    "inputs": {
      "model": "Wan2.2-I2V-A14B-fp8.safetensors",
      "base_precision": "fp8",
      "quantization": "fp8_e4m3fn",
      "load_device": "main_device",
      "attention_mode": "sageattn"
    },
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "Load Wan2.2 I2V Model" }
  },
  "2": {
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "bf16"
    },
    "class_type": "WanVideoVAELoader",
    "_meta": { "title": "Load Wan VAE" }
  },
  "3": {
    "inputs": {
      "model_name": "umt5-xxl-enc-bf16.safetensors",
      "precision": "bf16",
      "load_device": "offload_device"
    },
    "class_type": "LoadWanVideoT5TextEncoder",
    "_meta": { "title": "Load T5 Text Encoder" }
  },
  "20": {
    "inputs": {
      "image": "input_image.png",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Input Image (i2v start frame — injected at runtime)" }
  },
  "21": {
    "inputs": {
      "width": 1280,
      "height": 720,
      "num_frames": 81,
      "image": ["20", 0],
      "vae": ["2", 0]
    },
    "class_type": "WanVideoImageClipEncode",
    "_meta": { "title": "Encode Start Image" }
  },
  "30": {
    "inputs": {
      "positive_prompt": "gentle camera push-in, subtle natural movement, cinematic lighting preserved",
      "negative_prompt": "static, frozen, jittery, distorted, blurry, low quality, watermark, text, glitch",
      "t5": ["3", 0]
    },
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Motion Prompt (injected at runtime)" }
  },
  "40": {
    "inputs": {
      "steps": 30,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": 0,
      "scheduler": "unipc",
      "riflex_freq_index": 0,
      "model": ["1", 0],
      "image_embeds": ["21", 0],
      "text_embeds": ["30", 0]
    },
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Wan Sampler" }
  },
  "45": {
    "inputs": {
      "samples": ["40", 0],
      "vae": ["2", 0]
    },
    "class_type": "WanVideoDecode",
    "_meta": { "title": "Decode" }
  },
  "50": {
    "inputs": {
      "frame_rate": 16,
      "filename_prefix": "wan22_i2v",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": false,
      "pingpong": false,
      "save_output": true,
      "images": ["45", 0]
    },
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Save MP4" }
  }
}
