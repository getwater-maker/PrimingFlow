{
  "manifest_version": 3,
  "name": "우토그록 - Uto Grok",
  "version": "2.4.0",
  "author": "우미",
  "description": "grok.com 텍스트/이미지 동영상 일괄 생성 자동화 · 자동 다운로드 · 대기열 관리",
  "permissions": [
    "sidePanel", "storage", "downloads", "activeTab", "tabs", "scripting", "notifications", "identity", "identity.email"
  ],
  "host_permissions": ["https://grok.com/*", "https://imagine-public.x.ai/*", "https://script.google.com/*", "https://script.googleusercontent.com/*"],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "content_scripts": [{
    "matches": ["https://grok.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_icon": { "16":"icons/icon16.png","32":"icons/icon32.png","48":"icons/icon48.png","128":"icons/icon128.png" },
    "default_title": "우토그록 - Uto Grok"
  },
  "icons": { "16":"icons/icon16.png","32":"icons/icon32.png","48":"icons/icon48.png","128":"icons/icon128.png" }
}
